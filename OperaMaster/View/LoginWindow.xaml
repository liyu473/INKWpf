<Window
    x:Class="OperaMaster.View.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Width="500"
    Height="400"
    ui:WindowHelper.UseModernWindowStyle="True"
    ui:TitleBar.IsBackButtonVisible="False"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid Margin="40,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题区域 -->
        <StackPanel Grid.Row="0" Margin="0,20,0,30" HorizontalAlignment="Center">
            <TextBlock
                FontSize="28"
                FontWeight="Bold"
                Text="OperaMaster" />
            <TextBlock
                Margin="0,8,0,0"
                HorizontalAlignment="Center"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="请登录您的账户" />
        </StackPanel>

        <!-- 登录表单 -->
        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="用户名:" />
                <TextBox
                    x:Name="UsernameBox"
                    Grid.Column="1"
                    ui:ControlHelper.PlaceholderText="请输入用户名" />
            </Grid>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="密码:" />
                <PasswordBox
                    x:Name="PasswordBox"
                    Grid.Column="1"
                    ui:ControlHelper.PlaceholderText="请输入密码" />
            </Grid>

            <CheckBox
                x:Name="RememberCheckBox"
                Margin="80,0,0,24"
                Content="记住密码" />

            <Button
                Width="120"
                Height="36"
                Margin="80,0,0,0"
                HorizontalAlignment="Left"
                Click="LoginButton_Click"
                Content="登 录"
                Style="{StaticResource AccentButtonStyle}" />

            <TextBlock
                x:Name="ErrorText"
                Margin="80,16,0,0"
                Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
        </StackPanel>
    </Grid>
</Window>
